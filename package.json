{
  "name": "graphql-clnt",
  "displayName": "GraphQL CLNT",
  "description": "A full-featured GraphQL client for VS Code with collections, schema introspection, and query analysis",
  "version": "0.4.4",
  "publisher": "PoojithGavini",
  "repository": {
    "type": "git",
    "url": "https://github.com/poojithg14/GraphqlClient.git"
  },
  "author": "Poojith Gavini",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Testing"
  ],
  "keywords": [
    "graphql",
    "api",
    "client",
    "schema",
    "query"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "graphqlClient",
          "title": "GraphQL CLNT",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "graphqlClient": [
        {
          "type": "webview",
          "id": "graphqlClient.mainView",
          "name": "GraphQL CLNT"
        }
      ]
    },
    "commands": [
      {
        "command": "graphqlClient.open",
        "title": "Open GraphQL CLNT"
      },
      {
        "command": "graphqlClient.importCollection",
        "title": "GraphQL CLNT: Import Collection"
      },
      {
        "command": "graphqlClient.exportCollections",
        "title": "GraphQL CLNT: Export Collections"
      }
    ]
  },
  "homepage": "https://github.com/poojithg14/GraphqlClient",
  "bugs": {
    "url": "https://github.com/poojithg14/GraphqlClient/issues"
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
